services:
  openclaw-gateway:
    image: ghcr.io/openclaw/openclaw:latest
    container_name: openclaw{{N}}-gateway
    restart: unless-stopped
    environment:
      HOME: /home/node
      TERM: xterm-256color
      NPM_CONFIG_PREFIX: /home/node/.npm-global
      PATH: /home/node/.npm-global/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
      OPENCLAW_GATEWAY_TOKEN: ${OPENCLAW_GATEWAY_TOKEN:-}
      OPENCLAW_ALLOW_INSECURE_PRIVATE_WS: ${OPENCLAW_ALLOW_INSECURE_PRIVATE_WS:-}
      TZ: {{TZ}}
    volumes:
      - "{{DATA_DIR}}:/home/node/.openclaw"
      - "{{DATA_DIR}}/workspace:/home/node/.openclaw/workspace"
    ports:
      - "{{API_PORT}}:18789"
      - "{{WS_PORT}}:18790"
    init: true
    command:
      [
        "node",
        "dist/index.js",
        "gateway",
        "--bind",
        "${OPENCLAW_GATEWAY_BIND:-loopback}",
        "--port",
        "18789",
        "--allow-unconfigured",
      ]
    healthcheck:
      test:
        [
          "CMD",
          "node",
          "-e",
          "const c=new AbortController();const t=setTimeout(()=>c.abort(),4000);fetch('http://127.0.0.1:18789/healthz',{signal:c.signal}).then(r=>{clearTimeout(t);process.exit(r.ok?0:1)}).catch(()=>{clearTimeout(t);process.exit(1)})",
        ]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
