services:
  gateway:
    image: ghcr.io/phioranex/openclaw-docker:latest
    container_name: openclaw{{N}}-gateway
    restart: unless-stopped
    command: gateway start

    # OpenClaw inside container listens on 8789 (HTTP) and 8790 (WS)
    ports:
      - "{{API_PORT}}:8789"
      - "{{WS_PORT}}:8790"

    environment:
      # Optional: set timezone or any other env you want
      - TZ={{TZ}}

    volumes:
      # Instance data isolation – workspace/ is a subdirectory, no extra mount needed
      - "{{DATA_DIR}}:/home/node/.openclaw"
